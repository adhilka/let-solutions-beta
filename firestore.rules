rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && 
             request.auth.token != null &&
             request.auth.token.email_verified == true &&
             request.auth.token.email.lower() in ['sp.sanal3@gmail.com', 'muhammedadhil856@gmail.com'];
    }

    function isStockAdmin() {
      return request.auth != null && 
             request.auth.token != null &&
             request.auth.token.email_verified == true &&
             request.auth.token.email.lower() in ['muhammedadhil856@gmail.com', 'serviziotirur@gmail.com'];
    }

    function isSharedAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/artifacts/tech-institute/public/data/admin_sessions/$(request.auth.uid)) &&
             exists(/databases/$(database)/documents/artifacts/tech-institute/public/data/admin_links/$(get(/databases/$(database)/documents/artifacts/tech-institute/public/data/admin_sessions/$(request.auth.uid)).data.linkId)) &&
             get(/databases/$(database)/documents/artifacts/tech-institute/public/data/admin_links/$(get(/databases/$(database)/documents/artifacts/tech-institute/public/data/admin_sessions/$(request.auth.uid)).data.linkId)).data.expiresAt > request.time;
    }

    function hasAdminAccess() {
      return isAdmin() || isSharedAdmin();
    }

    // Admin access to standard content collections (excluding secure_backups and stocks)
    match /artifacts/tech-institute/public/data/{collection}/{document=**} {
      allow read: if collection != 'secure_backups';
      allow write: if hasAdminAccess() && collection != 'secure_backups' && collection != 'stocks' && collection != 'stock_history';
    }

    // Stock Management Protection
    match /artifacts/tech-institute/public/data/stocks/{id} {
      allow read, write: if isStockAdmin();
    }
    match /artifacts/tech-institute/public/data/stock_history/{id} {
      allow read, write: if isStockAdmin();
    }

    // Role detection documents (checks permission via path access)
    match /artifacts/tech-institute/public/roles/admin/check {
      allow read: if isAdmin();
    }
    match /artifacts/tech-institute/public/roles/stock/check {
      allow read: if isStockAdmin();
    }

    match /artifacts/tech-institute/public/data/admin_sessions/{uid} {
      allow create: if request.auth != null && request.auth.uid == uid &&
                    exists(/databases/$(database)/documents/artifacts/tech-institute/public/data/admin_links/$(request.resource.data.linkId)) &&
                    get(/databases/$(database)/documents/artifacts/tech-institute/public/data/admin_links/$(request.resource.data.linkId)).data.expiresAt > request.time;
      allow read: if request.auth != null && request.auth.uid == uid || hasAdminAccess();
    }

    // Public Guest read-only access to standard display content
    match /artifacts/tech-institute/public/data/courses/{id} {
      allow read: if true;
    }
    match /artifacts/tech-institute/public/data/testimonials/{id} {
      allow read: if true;
    }
    match /artifacts/tech-institute/public/data/batches/{id} {
      allow read: if true;
    }
    match /artifacts/tech-institute/public/data/offers/{id} {
      allow read: if true;
    }
    match /artifacts/tech-institute/public/data/posts/{id} {
      allow read: if true;
    }
    match /artifacts/tech-institute/public/data/settings/{id} {
      allow read: if true;
    }
    match /artifacts/tech-institute/public/data/gallery/{id} {
      allow read: if true;
    }
    match /artifacts/tech-institute/public/data/admin_links/{linkId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Specific collections that allow public submissions
    match /artifacts/tech-institute/public/data/enquiries/{enquiryId} {
      allow create: if true;
    }

    match /artifacts/tech-institute/public/data/secure_backups/{password} {
      allow read: if request.auth != null && password == '#09';
    }
  }
}
