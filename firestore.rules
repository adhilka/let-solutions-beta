rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'muhammedadhil856@gmail.com' && 
             request.auth.token.email_verified == true;
    }

    // Default deny
    match /{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Specific collections that allow public submissions
    match /artifacts/tech-institute/public/data/enquiries/{enquiryId} {
      allow create: if true;
    }

    match /artifacts/tech-institute/public/data/testimonials/{testimonialId} {
      allow create: if true;
    }
  }
}
